# HTTP port the server listens on.
# Pick one that isn't already used by another tool on the same VPS.
# AutoReel default ports in use:  5004-5015
# Recommended free range:         5016, 5017, 5018, ...
PORT=5016

# Optional: override the default content folder path shown in the UI.
# If unset, the app uses /root/<tool_name>content based on AI Settings → tool_name.
# DEFAULT_CONTENT_FOLDER=/root/imagestool1content
